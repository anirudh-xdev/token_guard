# Turso remote-only libSQL connection.
# Example: libsql://your-database-org.turso.io
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Upstash Redis REST connection.
# Example: https://your-redis-instance.upstash.io
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Core proxy server.
TOKENGUARD_LISTEN_ADDR=:8080
TOKENGUARD_UPSTREAM_URL=https://api.openai.com
TOKENGUARD_TOKENIZER_MODEL=gpt-4
TOKENGUARD_PRICING_FILE=pricing.json
TOKENGUARD_GUARD_ENABLED=true
TOKENGUARD_DEFAULT_MAX_OUTPUT_TOKENS=4096
TOKENGUARD_MAX_REQUEST_BYTES=4194304
TOKENGUARD_READ_HEADER_TIMEOUT_MS=2000
TOKENGUARD_SHUTDOWN_TIMEOUT_MS=5000

# Optional local cache for tiktoken dictionaries.
TIKTOKEN_CACHE_DIR=.tiktoken-cache

# Optional tuning defaults.
TOKENGUARD_DB_MAX_OPEN_CONNS=4
TOKENGUARD_REDIS_TIMEOUT_MS=750
TOKENGUARD_LOOP_TTL_SECONDS=180
TOKENGUARD_LOOP_THRESHOLD=3
TOKENGUARD_LOOP_KEY_PREFIX=tokenguard:loop
